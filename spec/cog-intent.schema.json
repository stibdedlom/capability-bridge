{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CogIntent",
  "description": "A COG-shaped intent ready for routing through the SDL capability bridge.",
  "type": "object",
  "required": [
    "contract_version",
    "trace_id",
    "source_intent",
    "user_goal",
    "locale",
    "confidence",
    "transcription",
    "timestamp"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "trace_id": {
      "type": "string"
    },
    "source_intent": {
      "$ref": "#/$defs/intent"
    },
    "user_goal": {
      "type": "string"
    },
    "target_query": {
      "type": [
        "string",
        "null"
      ]
    },
    "locale": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "transcription": {
      "type": "string"
    },
    "raw_audio_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp": {
      "type": "integer"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "intent": {
      "type": "object",
      "description": "The original workspace Intent that produced this COG intent.",
      "required": [
        "action",
        "parameters",
        "source",
        "confidence"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "switchTab",
            "readOutput",
            "takeNote",
            "sendInput",
            "groupTabs",
            "collapseGroup",
            "expandGroup",
            "statusBrief",
            "cancel",
            "correct",
            "pausePlayback",
            "resumePlayback",
            "annotate",
            "requestProactiveBriefing",
            "searchNotes",
            "addRule",
            "listRules",
            "saveSession",
            "loadSession"
          ],
          "description": "The action the core layer can perform."
        },
        "target_query": {
          "type": [
            "string",
            "null"
          ]
        },
        "parameters": {
          "type": "object",
          "description": "Key-value parameters that refine the action.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "source": {
          "type": "string",
          "enum": [
            "voice",
            "text",
            "api"
          ],
          "description": "The origin of an intent."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
