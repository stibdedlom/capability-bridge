{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CogTraceEvent",
  "description": "An append-only correlation record emitted from COG into SDL lifecycle records.",
  "type": "object",
  "required": [
    "contract_version",
    "trace_id",
    "event_id",
    "parent_event_id",
    "event_type",
    "subject_ref",
    "status",
    "outcome",
    "payload_summary",
    "payload_hash",
    "artifact_refs",
    "approval_refs",
    "timestamp"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "0.2.0"
    },
    "trace_id": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "parent_event_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_type": {
      "type": "string"
    },
    "subject_ref": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "payload_summary": {
      "type": "string"
    },
    "payload_hash": {
      "type": "string"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "integer"
    }
  },
  "additionalProperties": false
}
